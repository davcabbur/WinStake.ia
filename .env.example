# ==============================================
# WinStake.ia — Configuración de API Keys
# ==============================================
# Copia este archivo como .env y rellena tus claves:
#   copy .env.example .env

# The Odds API (https://the-odds-api.com/#get-access)
ODDS_API_KEY=tu_clave_aqui

# API-Football via RapidAPI (https://rapidapi.com/api-sports/api/api-football)
FOOTBALL_API_KEY=tu_clave_aqui

# API-Sports Basketball — NBA (https://rapidapi.com/api-sports/api/api-basketball)
# Mismo proveedor que API-Football. Solo necesaria si usas --sport nba con datos reales.
BASKETBALL_API_KEY=tu_clave_aqui

# Telegram Bot (@BotFather en Telegram)
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# API Key para proteger el dashboard FastAPI (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
DASHBOARD_API_KEY=tu_api_key_aqui
